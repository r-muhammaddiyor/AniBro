{
  "version": 2,
  "name": "AniBro",
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    { "src": "backend/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/$1.js" },
    { "src": "/(.*)", "dest": "frontend/dist/$1" }
  ]
}

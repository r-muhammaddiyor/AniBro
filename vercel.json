{
  "version": 2,
  "builds": [
    {
      "source": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "source": "backend/api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "source": "/api/(.*)",
      "dest": "/backend/api/$1.js"
    },
    {
      "source": "/(.*)",
      "dest": "/frontend/dist/index.html"
    }
  ]
}
